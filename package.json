{
  "name": "obligacje-calculator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scan:unused": "tsx scripts/run-unused-scan.ts",
    "test": "vitest",
    "test:browser": "playwright test tests/browser/app-smoke.spec.ts",
    "test:browser:ci": "playwright test tests/browser/app-smoke.spec.ts tests/browser/web-vitals.spec.ts --workers=1",
    "test:web-vitals": "playwright test tests/browser/web-vitals.spec.ts",
    "test:ci": "vitest run",
    "test:core": "vitest run features/bond-core",
    "test:release": "vitest run features/bond-core i18n/locale-parity.test.ts lib/data/bond-series.test.ts lib/data/macro-market-data.test.ts lib/data/market-data-cache.test.ts lib/page-metadata.test.ts lib/seo/app-json-ld.test.ts lib/sync/sync-engine.test.ts lib/sync/sync-start-year.test.ts shared/lib/data-freshness-display.test.ts shared/lib/regular-investment-display.test.ts shared/lib/bond-display.test.ts shared/workers/calculation-worker-contract.test.ts app/api/production-readiness-contract.test.ts app/api/operational-endpoints-contract.test.ts app/seo-metadata-contract.test.ts docs/ui/interactive-trigger-markup-contract.test.ts docs/technical/architecture/deployment-contract.test.ts docs/technical/architecture/clean-code-contract.test.ts docs/product/product-readiness-contract.test.ts docs/product/release-scope-contract.test.ts scripts/check-production-config.test.ts scripts/verify-production.test.ts package-scripts-contract.test.ts",
    "check:types": "tsc --noEmit",
    "check:release": "pnpm check:types && pnpm lint && pnpm test:release && pnpm build",
    "check:local-env": "tsx scripts/check-local-env.ts",
    "check:prod-config": "tsx scripts/check-production-config.ts",
    "smoke:local": "tsx scripts/smoke-local.ts",
    "gcp:proxy": "gcloud run services proxy obligacje-calculator --project bond-calculator-pl --region europe-central2 --port 8080",
    "ops:cloud-run-status": "tsx scripts/cloud-run-status.ts",
    "ops:verify-prod": "tsx scripts/verify-production.ts",
    "db:seed": "tsx db/seed.ts",
    "seed:series": "tsx lib/sync/seed-series-runner.ts",
    "seed:market-history": "tsx lib/sync/seed-market-history.ts",
    "db:seed:production": "tsx lib/sync/seed-production-bonds.ts && tsx lib/sync/seed-production-data.ts",
    "sync:market-history": "tsx lib/sync/sync-market-history.ts",
    "sync:bond-offers": "tsx lib/sync/run-full-sync.ts",
    "sync:full": "tsx lib/sync/run-full-sync.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c \"pnpm exec tsc --noEmit\"",
      "bash -c \"pnpm test:core\""
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.1",
    "inngest": "^3.54.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.12.0",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.6",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.22.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
