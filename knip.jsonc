{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "db/**/*.ts",
    "docs/**/*.ts",
    "features/**/*.{ts,tsx}",
    "i18n/**/*.{ts,tsx}",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "shared/**/*.{ts,tsx}",
    "*.config.{ts,js,mjs}",
    "*.config.ts",
    "*.test.{ts,tsx}",
    "auth.ts",
  ],
  "ignoreDependencies": ["shadcn", "tailwindcss", "tailwindcss-animate", "tw-animate-css"],
}
