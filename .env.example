# Local development defaults. Copy to .env.local or let Docker Compose inject
# these values for containerized local development.
DATABASE_URL=postgresql://obligacje:obligacje@localhost:5432/obligacje?sslmode=disable
AUTH_SECRET=local-development-auth-secret-change-me
SYNC_SECRET=local-development-sync-secret-change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Optional OAuth providers. Leave empty for local calculator-only work.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
